---
import Layout from '../layouts/Layout.astro';
import about from '../content/pages/about.json';

export const prerender = true;
---
<Layout title={about.title} currentPage="nosotros">
<section class="bg-primary py-section-padding-mobile md:py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-base md:px-gutter grid md:grid-cols-2 gap-gutter items-center">
<div class="text-on-primary reveal">
<h1 class="font-display-hero-mobile md:font-display-hero text-display-hero-mobile md:text-display-hero mb-6">
                    {about.heroHeading}
                </h1>
<p class="font-body-lg text-body-lg opacity-90 max-w-xl mb-10">
                    {about.heroParagraph}
                </p>
<div class="flex gap-4">
<a href={about.heroCtaPrimary.href} class="bg-on-primary text-primary font-label-sm text-label-sm px-8 py-4 rounded-full font-bold btn-magnetic press-effect inline-flex">
                        <span class="icon-wrap">{about.heroCtaPrimary.label}</span>
                    </a>
<a href={about.heroCtaSecondary.href} class="border-2 border-on-primary text-on-primary font-label-sm text-label-sm px-8 py-4 rounded-full font-bold hover:bg-on-primary hover:text-primary transition-all btn-magnetic inline-flex">
                        <span class="icon-wrap">{about.heroCtaSecondary.label}</span>
                    </a>
</div>
</div>
<div class="relative mt-12 md:mt-0 reveal">
<div class="absolute -inset-4 bg-white/10 rounded-card blur-2xl"></div>
<img alt={about.heroImageAlt} class="relative z-10 w-full rounded-card shadow-2xl" src={about.heroImage}>
</div>
</div>
</section>
<section id="esencia" class="bg-surface-container-low py-section-padding-mobile md:py-section-padding-desktop overflow-hidden">
<div class="max-w-container-max mx-auto px-base md:px-gutter grid lg:grid-cols-12 gap-12 items-center">
<div class="lg:col-span-5 relative reveal">
<img alt={about.esenciaImageAlt} class="w-full h-auto rounded-card shadow-xl border-4 border-white" src={about.esenciaImage}>
<div class="absolute -bottom-10 -right-10 hidden md:block">
<div class="bg-primary text-on-primary p-8 rounded-card shadow-lg max-w-[240px]">
<span class="font-display-hero-mobile text-display-hero-mobile block">{about.esenciaBadgeValue}</span>
<span class="font-body-md text-body-md">{about.esenciaBadgeLabel}</span>
</div>
</div>
</div>
<div class="lg:col-span-7 reveal">
<span class="text-primary font-label-sm text-label-sm uppercase tracking-widest mb-4 block">{about.esenciaTag}</span>
<h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-8">
                    {about.esenciaHeading}
                </h2>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-10 leading-relaxed">
                    {about.esenciaParagraph}
                </p>
<a href="/contacto" class="bg-primary text-on-primary font-label-sm text-label-sm px-10 py-5 rounded-full btn-magnetic press-effect shadow-md shadow-primary/20 inline-flex">
                    <span class="icon-wrap">{about.esenciaCtaLabel}</span>
                </a>
</div>
</div>
</section>
<section class="bg-surface py-section-padding-mobile md:py-section-padding-desktop">
<div class="max-w-3xl mx-auto px-base md:px-gutter text-center">
<div class="w-16 h-1 bg-primary mx-auto mb-10"></div>
<h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-8">
                {about.quienesHeading}
            </h2>
<p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed mb-8">
                {about.quienesParagraph}
            </p>
<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-16">
{about.stats.map(s => (
<div>
<div class="text-primary font-bold text-headline-md font-headline-md mb-2">{s.value}</div>
<div class="text-on-surface-variant font-label-sm text-label-sm uppercase">{s.label}</div>
</div>
))}
</div>
</div>
</section>
<section class="bg-surface-container-low py-section-padding-mobile md:py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-base md:px-gutter">
<div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
<div class="max-w-2xl">
<h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-4">
                        {about.teamHeading}
                    </h2>
<p class="font-body-lg text-body-lg italic text-primary">
                        {about.teamQuote}
                    </p>
</div>
<a href="/contacto" class="bg-primary text-on-primary font-label-sm text-label-sm px-8 py-4 rounded-full font-bold btn-magnetic press-effect shadow-md shadow-primary/20 whitespace-nowrap inline-flex">
                    <span class="icon-wrap">{about.teamCtaLabel}</span>
                </a>
</div>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
{about.team.map(m => (
<div class="group cursor-pointer stagger-fade">
<div class="overflow-hidden rounded-card mb-4 bg-on-surface aspect-square">
<img alt={m.name} class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-500" src={m.img}>
</div>
<h3 class="font-headline-md text-headline-md text-on-surface">{m.name}</h3>
<p class="text-primary font-body-md text-body-md">{m.role}</p>
</div>
))}
</div>
</div>
</section>
</Layout>
