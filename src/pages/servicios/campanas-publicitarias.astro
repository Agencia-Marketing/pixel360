<Layout title="Campañas Publicitarias | Plantilla 1">
<!-- 2. Hero Section -->
<!-- Hero Section -->
<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 bg-primary-container overflow-hidden">
<div class="max-w-container-max mx-auto px-gutter relative z-10 text-center">
