<div class="absolute bottom-10 right-10 w-96 h-96 bg-on-primary-container rounded-full blur-[120px]"></div>
</div>
</section>
<!-- 3. Benefits Bar -->
<section class="bg-white py-20 relative -mt-10 mx-auto max-w-[1200px] rounded-xl shadow-xl z-20">
