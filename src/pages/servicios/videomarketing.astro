---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Videomarketing | Pixel 360">
<!-- Hero Section -->
<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 bg-primary overflow-hidden">
<div class="max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
<div class="space-y-6 reveal in-view">
<h1 class="font-display-hero-mobile md:font-display-hero text-display-hero-mobile md:text-display-hero text-on-primary">
                VIDEOMARKETING ESTRATÉGICO
            </h1>
<p class="font-body-lg text-body-lg text-on-primary/90 max-w-xl">
                Captura la atención de tu audiencia y multiplica tus conversiones con contenido audiovisual diseñado para destacar y vender en cualquier plataforma.
            </p>
</div>
<div class="relative reveal in-view">
<img alt="Videomarketing Editorial Studio" class="w-full rounded-2xl shadow-2xl border border-white/20" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBFUqr1X_pwtHpAKqWNwAPUSlJ5tT3-T5BKTSC_M6ISDLBXNT8Qn2TXvA5C96UgXUfZWfmKJEBv_P18mnzfeewriiEUJeqGpsW2RQD42EgsMFXzHumLN8B9plFTZK-Tn13ozZTVgeuSreTazqm2zALs6LIaFQhsnPZRkUSifKNYZxrxmBZNEyIJgNBmtmtSJ6khRZEWRWUyd1OKtWPnCTrXH_LcAGdxLAZ-F8gpFolWeiiMFWUwJXSRsbAbEK-qCoq8JEvpTtjdOLqs"/>
</div>
</div>
<!-- Background accents -->
<div class="absolute top-0 left-0 w-full h-full pointer-events-none opacity-20">
<div class="absolute top-20 left-10 w-64 h-64 bg-primary-fixed rounded-full blur-[100px]"></div>
<div class="absolute bottom-10 right-10 w-96 h-96 bg-on-primary-container rounded-full blur-[120px]"></div>
</div>
</section>
<!-- Benefits Bar -->
<section class="bg-surface-container-lowest py-16">
<div class="max-w-container-max mx-auto px-gutter">
<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
<div class="flex items-center gap-6 p-4">
<div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="favorite">favorite</span>
</div>
<div>
<h4 class="font-headline-md text-headline-md text-on-surface">Mayor Retención</h4>
<p class="font-body-md text-body-md text-on-surface-variant">Conectamos emocionalmente.</p>
</div>
</div>
<div class="flex items-center gap-6 p-4">
<div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="trending_up">trending_up</span>
</div>
<div>
<h4 class="font-headline-md text-headline-md text-on-surface">Alcance Viral</h4>
<p class="font-body-md text-body-md text-on-surface-variant">Contenido diseñado para compartir.</p>
</div>
</div>
<div class="flex items-center gap-6 p-4">
<div class="w-16 h-16 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="devices">devices</span>
</div>
<div>
<h4 class="font-headline-md text-headline-md text-on-surface">Multiplataforma</h4>
<p class="font-body-md text-body-md text-on-surface-variant">Adaptable a todo formato.</p>
</div>
</div>
</div>
</div>
</section>
<!-- Plans Section -->
<section class="bg-surface-container-low py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter">
<h2 class="font-headline-lg text-headline-lg text-center text-on-surface mb-20">Nuestros Planes</h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
<!-- Plan 1 -->
<div class="bg-white p-10 rounded-xl border border-outline-variant/30 transition-standard hover:shadow-xl group">
<div class="text-primary mb-6 group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined text-5xl" data-icon="videocam">videocam</span>
</div>
<h3 class="font-headline-md text-headline-md mb-2">Video Básico</h3>
<p class="text-primary font-bold text-2xl mb-6">$40 - $100 <span class="text-base font-normal text-on-surface-variant">USD</span></p>
<ul class="space-y-4 mb-10 text-on-surface-variant font-body-md">
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Transiciones simples</li>
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Textos 2D</li>
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Música de fondo</li>
</ul>
<a href="/producto?service=videomarketing&plan=basico" class="w-full border-2 border-primary text-primary font-bold py-3 rounded-lg hover:bg-primary hover:text-white transition-standard press-effect text-center block">Seleccionar</a>
</div>
<!-- Plan 2 (Featured) -->
<div class="bg-white p-10 rounded-xl border-2 border-primary-container shadow-2xl relative transform scale-105 z-10">
<div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary-container text-white px-4 py-1 rounded-full text-sm font-bold uppercase tracking-wider">Recomendado</div>
<div class="text-primary mb-6">
<span class="material-symbols-outlined text-5xl" data-icon="perm_media">perm_media</span>
</div>
<h3 class="font-headline-md text-headline-md mb-2">Video Inter</h3>
<p class="text-primary font-bold text-2xl mb-6">$75 - $200 <span class="text-base font-normal text-on-surface-variant">USD</span></p>
<ul class="space-y-4 mb-10 text-on-surface-variant font-body-md">
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Transiciones elaboradas</li>
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Uso de mockups</li>
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Música sin copyright</li>
</ul>
<a href="/producto?service=videomarketing&plan=inter" class="w-full bg-primary-container text-on-primary font-bold py-3 rounded-lg hover:opacity-90 transition-standard btn-magnetic press-effect text-center block"><span class="icon-wrap">Seleccionar</span></a>
</div>
<!-- Plan 3 -->
<div class="bg-white p-10 rounded-xl border border-outline-variant/30 transition-standard hover:shadow-xl group">
<div class="text-primary mb-6 group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined text-5xl" data-icon="movie">movie</span>
</div>
<h3 class="font-headline-md text-headline-md mb-2">Video Completo</h3>
<p class="text-primary font-bold text-2xl mb-6">$100 - $500 <span class="text-base font-normal text-on-surface-variant">USD</span></p>
<ul class="space-y-4 mb-10 text-on-surface-variant font-body-md">
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Transiciones y mockups</li>
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Animaciones</li>
<li class="flex items-center gap-2"><span class="material-symbols-outlined text-primary text-sm">check_circle</span> Múltiples formatos</li>
</ul>
<a href="/producto?service=videomarketing&plan=completo" class="w-full border-2 border-primary text-primary font-bold py-3 rounded-lg hover:bg-primary hover:text-white transition-standard press-effect text-center block">Seleccionar</a>
</div>
</div>
</div>
</section>
<!-- Special Service (Voiceover) -->
<section class="bg-surface-container-lowest py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter">
<div class="bg-surface-container-low rounded-xl overflow-hidden grid grid-cols-1 md:grid-cols-2">
<div class="p-12 md:p-20 flex flex-col justify-center">
<h3 class="font-headline-lg text-headline-lg mb-4">Narración de voz (Voiceover)</h3>
<div class="text-primary font-bold text-3xl mb-6">$30 - $50 <span class="text-lg font-normal text-on-surface-variant">USD</span></div>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-10">
                        Dale alma a tus videos con locutores profesionales. Una voz adecuada puede aumentar la confianza en tu marca hasta en un 40%.
                    </p>
<div>
<a href="/producto?service=videomarketing&plan=voz-off" class="bg-primary-container text-on-primary px-10 py-4 rounded-lg font-bold hover:scale-105 transition-standard btn-magnetic press-effect text-center inline-block"><span class="icon-wrap">CONTRATAR</span></a>
</div>
</div>
<div class="relative min-h-[400px]">
<img alt="Professional Studio Mic Setup" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBPKu42EU8B_dEIfFjWWQUnk_cu_9F_9uf9zrJXF5trnZ7z9iFlWYnV-trQeUe5SVlG5fVQ6hsCzIPWpzp9TV6FP_35sI9gDGvfzVl0UlPNkwl1HC_kBA3wnnmPhzGDLztMHr34wgyHk2ummY7i24dkRCr3IjkM_amuO0tHNNbQ8LouuEvMEeqJd6YfcSLk9jVbt3rB5wJccUcT-Jp9gvsaAhn8NQpk1It8V8OQMKkRWKY6FEgnbWhMlmbvB22TJYst_w7pUZhEnMMg"/>
</div>
</div>
</div>
</section>
<!-- Tables Section -->
<section class="bg-surface-container-lowest py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter">
<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
<!-- Table 1: Subscription -->
<div class="bg-white rounded-xl border border-outline-variant/30 overflow-hidden">
<div class="bg-primary-fixed-dim p-4">
<h4 class="font-bold text-on-primary-fixed-variant">Suscripción Mensual</h4>
</div>
<table class="w-full text-left font-body-md">
<tbody><tr class="border-b border-outline-variant/20"><th class="p-4 bg-surface-container">Nivel</th><th class="p-4 bg-surface-container">Frecuencia</th></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Básico</td><td class="p-4">2 Videos/Mes</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Intermedio</td><td class="p-4">5 Videos/Mes</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Completo</td><td class="p-4">12 Videos/Mes</td></tr>
</tbody></table>
</div>
<!-- Table 2: Content Creator -->
<div class="bg-white rounded-xl border border-outline-variant/30 overflow-hidden">
<div class="bg-primary-fixed-dim p-4">
<h4 class="font-bold text-on-primary-fixed-variant">Creador de Contenido</h4>
</div>
<table class="w-full text-left font-body-md">
<tbody><tr class="border-b border-outline-variant/20"><th class="p-4 bg-surface-container">Servicio</th><th class="p-4 bg-surface-container">Plataforma</th></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">TikTok/Reels</td><td class="p-4">Social Media</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Scripting</td><td class="p-4">Estratégico</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Pack 5 videos</td><td class="p-4">Campaña</td></tr>
</tbody></table>
</div>
<!-- Table 3: Logo Animation -->
<div class="bg-white rounded-xl border border-outline-variant/30 overflow-hidden">
<div class="bg-primary-fixed-dim p-4">
<h4 class="font-bold text-on-primary-fixed-variant">Animación de Logo</h4>
</div>
<table class="w-full text-left font-body-md">
<tbody><tr class="border-b border-outline-variant/20"><th class="p-4 bg-surface-container">Estilo</th><th class="p-4 bg-surface-container">Entrega</th></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">2D Minimal</td><td class="p-4">48 Horas</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">3D Dinámico</td><td class="p-4">5 Días</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">VFX Premium</td><td class="p-4">7 Días</td></tr>
</tbody></table>
</div>
<!-- Table 4: Format Change -->
<div class="bg-white rounded-xl border border-outline-variant/30 overflow-hidden">
<div class="bg-primary-fixed-dim p-4">
<h4 class="font-bold text-on-primary-fixed-variant">Cambio de Formato</h4>
</div>
<table class="w-full text-left font-body-md">
<tbody><tr class="border-b border-outline-variant/20"><th class="p-4 bg-surface-container">Conversión</th><th class="p-4 bg-surface-container">Uso</th></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Hori a Vert</td><td class="p-4">Shorts/Reels</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Vert a Hori</td><td class="p-4">YouTube/TV</td></tr>
<tr class="border-b border-outline-variant/20"><td class="p-4">Re-encuadre AI</td><td class="p-4">Automático</td></tr>
</tbody></table>
</div>
</div>
</div>
</section>
</Layout>
