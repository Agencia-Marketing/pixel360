---
import Layout from '../layouts/Layout.astro';
import home from '../content/pages/home.json';

export const prerender = true;
---
<Layout title={home.title}>
<section class="bg-primary relative overflow-hidden pt-12 pb-24 md:py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
<div class="text-on-primary space-y-8 reveal in-view">
<h1 class="font-display-hero-mobile text-display-hero-mobile md:font-display-hero md:text-display-hero">
                    {home.heroHeading}
                </h1>
<p class="font-body-lg text-body-lg text-on-primary/90 max-w-xl">
                    {home.heroParagraph}
                </p>
<div>
<button onclick="document.getElementById('servicios').scrollIntoView({behavior:'smooth'})" class="bg-surface-container-lowest text-primary px-8 py-4 rounded-2xl font-bold font-body-md text-body-md btn-magnetic shadow-xl press-effect">
                        <span class="icon-wrap">{home.heroCtaLabel}</span>
                    </button>
</div>
</div>
<div class="relative reveal in-view">
<img alt={home.heroImageAlt} class="w-full h-auto object-contain drop-shadow-2xl" src={home.heroImage}>
</div>
</div>
<div class="absolute -top-24 -right-24 w-96 h-96 bg-white/[0.06] rounded-full" style="filter:blur(80px)"></div>
<div class="absolute -bottom-12 -left-12 w-72 h-72 bg-white/[0.04] rounded-full" style="filter:blur(80px)"></div>
</section>
<section class="bg-surface py-section-padding-mobile md:py-section-padding-desktop" id="servicios">
<div class="max-w-container-max mx-auto px-gutter">
<div class="text-center mb-16 space-y-4 reveal">
<h2 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-on-surface">{home.servicesHeading}</h2>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
                    {home.servicesParagraph}
                </p>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {home.services.map(s => (
            <div class="bg-white p-8 rounded-2xl border border-outline-variant/30 hover:border-primary/50 transition-all group flex flex-col h-full shadow-sm card-hover stagger-fade">
                <div class="w-12 h-12 bg-primary-fixed rounded-xl flex items-center justify-center text-primary mb-6">
                    <span class="material-symbols-outlined">{s.icon}</span>
                </div>
                <h3 class="font-headline-md text-headline-md mb-4">{s.title}</h3>
                <p class="text-on-surface-variant font-body-md text-body-md mb-8 flex-grow">
                    {s.desc}
                </p>
                <a href={s.href} class="w-full bg-primary text-on-primary py-3 rounded-xl font-bold text-center block btn-magnetic press-effect shadow-md shadow-primary/20">
                    + Info
                </a>
            </div>
            ))}
        </div>
</div>
</section>
<section class="bg-primary py-section-padding-mobile md:py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter">
<div class="text-center mb-16 space-y-4">
<h2 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-on-primary">{home.reasonsHeading}</h2>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/10 rounded-2xl overflow-hidden border border-white/20">
{home.reasons.map(r => (
<div class="p-12 glass-card">
<span class="font-headline-md text-headline-md text-on-primary mb-4 block">{r.title}</span>
<p class="text-on-primary/70 font-body-md text-body-md">
                        {r.desc}
                    </p>
</div>
))}
</div>
</div>
</section>
<section class="bg-surface py-section-padding-mobile md:py-section-padding-desktop">
<div class="max-w-container-max mx-auto px-gutter">
<div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-outline-variant/30 grid grid-cols-1 md:grid-cols-2 items-center">
<div class="p-12 md:p-20 space-y-8">
<h2 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg text-on-surface">{home.ctaHeading}</h2>
<p class="font-body-lg text-body-lg text-on-surface-variant">
                        {home.ctaParagraph}
                    </p>
<button onclick="window.location.href='/contacto'" class="bg-primary text-on-primary px-10 py-4 rounded-2xl font-bold btn-magnetic press-effect shadow-md shadow-primary/20">
                        <span class="icon-wrap">{home.ctaLabel}</span>
                    </button>
</div>
<div class="h-full">
<img alt={home.ctaImageAlt} class="w-full h-full object-cover" src={home.ctaImage}>
</div>
</div>
</div>
</section>
</Layout>
